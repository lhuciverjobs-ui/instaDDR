NODE_ENV=production
PORT=8080
APP_PASSWORD=change-this-admin-password
AUTH_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
ALLOWED_ORIGINS=https://your-domain.com
RATE_LIMIT_PER_MINUTE=120

# Optional local-only helper when Kuku.lu asks for Turnstile.
# Paste a verified m.kuku.lu Cookie header here on your machine, never commit it.
KUKU_COOKIE=
